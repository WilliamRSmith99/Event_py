# ============================================================
# Overlap Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# ------------------------------------------------------------
# Discord (Optional)
# ------------------------------------------------------------

# Restrict slash commands to one guild during development.
# Omit (or leave blank) for global commands (up to 1 hour propagation).
# DEV_GUILD_ID=123456789012345678

# ------------------------------------------------------------
# Data Storage
# ------------------------------------------------------------

# Directory where SQLite database and data files are stored.
# Default: ./data  (inside the project/container)
# DATA_DIR=/app/data

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ------------------------------------------------------------
# Feature Limits
# ------------------------------------------------------------

# Maximum active events for free-tier servers (default: 5)
# FREE_TIER_MAX_EVENTS=5

# Maximum active events for premium servers (default: 999 = unlimited)
# PREMIUM_TIER_MAX_EVENTS=999

# ------------------------------------------------------------
# Stripe (leave blank to disable premium/subscription features)
# ------------------------------------------------------------

# From your Stripe dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret (Stripe → Webhooks → your endpoint → Signing secret)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for your subscription plans
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...

# ------------------------------------------------------------
# Web Server (required when Stripe is configured)
# ------------------------------------------------------------

# IMPORTANT: Set this to your public HTTPS URL in production.
# Stripe will call WEB_BASE_URL/webhook/stripe for payment events.
# localhost will NOT work in production — Stripe cannot reach it.
# WEB_BASE_URL=https://your-domain.com

# Internal bind address and port (default: 0.0.0.0:8080)
# WEB_HOST=0.0.0.0
# WEB_PORT=8080

# Redirect URLs after Stripe checkout
# STRIPE_SUCCESS_URL=https://discord.com/channels/@me
# STRIPE_CANCEL_URL=https://discord.com/channels/@me

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------

# Set to "production" to enable stricter validation
# ENV=production
